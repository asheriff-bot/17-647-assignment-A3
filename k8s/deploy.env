AWS_REGION=us-east-1
EKS_CLUSTER_NAME=bookstore-dev-BookstoreEKSCluster

# Image registry prefix, e.g. docker.io/username or <acct>.dkr.ecr.us-east-1.amazonaws.com
IMAGE_REGISTRY=YOUR_REGISTRY
IMAGE_TAG=latest

# Datastore / messaging
RDS_ENDPOINT=YOUR_RDS_ENDPOINT
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
KAFKA_BROKERS=YOUR_KAFKA_BROKERS
# Optional (MSK / TLS / SASL). Default PLAINTEXT for plain brokers.
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SSL_CAFILE=/path/to/ca.pem
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Assignment identifiers (replace with your values)
ANDREW_ID=asheriff
EMAIL_ADDRESS=asheriff@andrew.cmu.edu

# CMU 17-647 A3 recommendation service (Canvas):
# - Testing / AWS before submit (zero delay): http://52.73.13.84
# - Gradescope submission (variable delay):   http://100.51.187.149
# OpenAPI path: GET /recommended-titles/isbn/{isbn}
RECOMMENDATION_SERVICE_URL=http://100.51.187.149
RECOMMENDATION_PATH_TEMPLATE=/recommended-titles/isbn/{isbn}

# SMTP (CRM service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=asheriff@andrew.cmu.edu
SMTP_PASSWORD=app_password
SMTP_SENDER_EMAIL=asheriff@andrew.cmu.edu
