AWS_REGION=us-east-1
EKS_CLUSTER_NAME=bookstore-dev-BookstoreEKSCluster

# Image registry (images must exist here before render + kubectl apply)
IMAGE_REGISTRY=docker.io/akramdocke
IMAGE_TAG=a3-latest

# Aurora writer hostname only (no port, no https). Must match your stack.
# CloudFormation Output: DBClusterEndpoint
# Or: aws rds describe-db-clusters --region us-east-1 \
#   --query "DBClusters[?DBClusterIdentifier=='bookstore-db-dev'].Endpoint" --output text
RDS_ENDPOINT=bookstore-db-dev-instance1.cgqb4yinmv3k.us-east-1.rds.amazonaws.com
# Must match CloudFormation parameters DBUsername / DBPassword
DB_USER=admin123
DB_PASSWORD=admin123

# A3 course Kafka: all bootstrap brokers, comma-separated (from Canvas)
KAFKA_BROKERS=52.73.13.84:9092,100.51.187.149:9092,52.54.87.18:9092
# Optional (MSK / TLS / SASL). Default PLAINTEXT for plain brokers.
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SSL_CAFILE=/path/to/ca.pem
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

ANDREW_ID=asheriff
EMAIL_ADDRESS=asheriff@andrew.cmu.edu

# CMU 17-647 A3 recommendation service (Canvas):
# - Testing / low latency: http://52.73.13.84
# - Gradescope autograder (variable delay): http://100.51.187.149
RECOMMENDATION_SERVICE_URL=http://100.51.187.149
RECOMMENDATION_PATH_TEMPLATE=/recommended-titles/isbn/{isbn}

# SMTP (CRM). Use a Gmail App Password, not your normal login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=asheriff@andrew.cmu.edu
SMTP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD
SMTP_SENDER_EMAIL=asheriff@andrew.cmu.edu
