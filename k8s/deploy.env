# Required by DEPLOY_A3_EKS.md and scripts/render_k8s_from_env.sh (all variables below must be set).
# Build images with the same tag:  export TAG=a3-latest DH=akramdocke  &&  ./scripts/build-push-dockerhub-amd64.sh
# url.txt line 3 must match ANDREW_ID; line 4 must match EMAIL_ADDRESS and SMTP_SENDER_EMAIL.

AWS_REGION=us-east-1
EKS_CLUSTER_NAME=bookstore-dev-BookstoreEKSCluster

# Docker Hub: must match what you pushed (DH + TAG in build-push script).
IMAGE_REGISTRY=docker.io/akramdocke
IMAGE_TAG=a3-latest

# Aurora cluster writer endpoint (hostname only; no port). Prefer "cluster-..." from:
#   aws rds describe-db-clusters --region us-east-1 \
#     --query "DBClusters[?DBClusterIdentifier=='bookstore-db-dev'].Endpoint" --output text
# or CloudFormation output DBClusterEndpoint (not the instance-only endpoint, if both are listed).
# After RDS is reachable (bastion / same VPC): mysql -h "$RDS_ENDPOINT" -u "$DB_USER" -p"$DB_PASSWORD" < scripts/init_db.sql
# (from repo root). Required — without it you get MySQL 1049 / HTTP 500 on POST /books and POST /customers.
RDS_ENDPOINT=bookstore-db-dev.cluster-cgqb4yinmv3k.us-east-1.rds.amazonaws.com
# Must match CloudFormation parameters DBUsername / DBPassword
DB_USER=admin123
DB_PASSWORD=admin123

# All bootstrap brokers from Canvas, comma-separated host:port
KAFKA_BROKERS=52.73.13.84:9092,100.51.187.149:9092,52.54.87.18:9092
# Optional (MSK / TLS / SASL). Default PLAINTEXT for course brokers.
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SSL_CAFILE=/path/to/ca.pem
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

ANDREW_ID=asheriff
EMAIL_ADDRESS=asheriff@andrew.cmu.edu

# Gradescope autograder: http://100.51.187.149 | Local/low-latency testing: http://52.73.13.84
RECOMMENDATION_SERVICE_URL=http://100.51.187.149
RECOMMENDATION_PATH_TEMPLATE=/recommended-titles/isbn/{isbn}

# CRM email (required for activation-email behavior). Use a Gmail App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=asheriff@andrew.cmu.edu
SMTP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD
SMTP_SENDER_EMAIL=asheriff@andrew.cmu.edu
