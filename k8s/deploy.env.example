AWS_REGION=us-east-1
EKS_CLUSTER_NAME=bookstore-dev-BookstoreEKSCluster

# Image registry prefix, e.g. docker.io/username or <acct>.dkr.ecr.us-east-1.amazonaws.com
IMAGE_REGISTRY=YOUR_REGISTRY
IMAGE_TAG=latest

# Datastore / messaging
RDS_ENDPOINT=YOUR_RDS_ENDPOINT
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
KAFKA_BROKERS=YOUR_KAFKA_BROKERS
# Optional (MSK / TLS / SASL). Default PLAINTEXT for plain brokers.
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SSL_CAFILE=/path/to/ca.pem
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Assignment identifiers
ANDREW_ID=your_andrew_id
EMAIL_ADDRESS=your_email@gmail.com

# Recommendation engine used by grading
RECOMMENDATION_SERVICE_URL=YOUR_RECOMMENDATION_SERVICE_URL
RECOMMENDATION_PATH_TEMPLATE=/api/recommendations/{isbn}

# SMTP (CRM service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=app_password
SMTP_SENDER_EMAIL=your_email@gmail.com
